# Convex application deployment URL, ending in .convex.cloud
CONVEX_URL=
# Shared server-only token. Set the same value in Sites and Convex.
CONVEX_API_TOKEN=

# Convex research adapter mode: disabled, mock, or live
HERMES_ADAPTER_MODE=disabled
# Required only for live mode. The endpoint must return the JSON contract in convex/README.md.
HERMES_RESEARCH_WEBHOOK_URL=
HERMES_WORKER_TOKEN=

